# n8n Configuration - Homelab
# Created: 2026-01-08

n8n:
  url: http://n8n.cluster.local
  credentials:
    username: admin
    password: changeme
  webhook_secret: changeme

postgresql:
  host: postgresql.automation.svc.cluster.local
  port: 5432
  database: n8n
  username: n8n
  password: changeme

gpt_os:
  orchestrator_url: http://10.0.2.30:8000
  endpoints:
    orchestrate: /orchestrate
    health: /health
    stats: /stats

discord:
  webhook_url: "https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_DISCORD_WEBHOOK_HERE"

prometheus:
  url: http://prometheus.cluster.local
  alertmanager_webhook: http://n8n.cluster.local/webhook/prometheus-alerts

uptime_kuma:
  url: http://uptime.cluster.local
  # API token if needed

kubernetes:
  api_url: https://10.0.1.10:6443
  # Service account token mounted in pod
